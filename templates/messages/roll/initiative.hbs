<div class="S0-message-content">
  <h4 class="S0-text-center">{{localize 'S0.Iniciativa'}}</h4>
  <hr>
  <div class="dice-tooltip S0-container-contract">
    {{> default-dices values=diceValues}}

    <label class="S0-block S0-my-6">{{localize 'S0.Base'}}: {{ initiative }}</label>
    <label class="S0-block S0-my-6">{{localize 'S0.Total'}}: {{ total }}</label>
  </div>

  <button class="S0-roll-result" data-action="view" data-type="toggle-tooltip">( {{ total }} )</button>
</div>