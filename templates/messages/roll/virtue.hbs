<div class="S0-message-content">
  <h4 class="S0-text-center">{{localize virtue1}} + {{localize virtue2}}</h4>
  <hr>

  <div class="dice-tooltip S0-container-contract">
    <p>{{localize 'S0.Teste'}}: {{ formule }}</p>

    <hr>

    {{#unless (operators 'isEmpty' diceValues)}}
    <p>{{localize 'S0.Rolagem'}}:</p>
    {{> default-dices values=diceValues}}
    {{/unless}}

    <hr>

    <div class="S0-container-2-column">
      {{!-- <label>{{localize 'S0.Sucessos'}}: {{ resultValue }} </label> --}}
      <label>{{localize 'S0.Dificuldade'}}: {{ difficulty }}</label>
    </div>

    <hr>

    <!-- #region BONUS and PENALTY -->
    {{#if (operators 'or' (operators 'gt' penalty 0) (operators 'gt' bonus 0))}}
    <div class="S0-container-2-column">
      {{#if (operators 'gt' bonus 0)}}
      <label>{{localize 'S0.Bonus'}}: {{ bonus }}</label>
      {{/if}}

      {{#if (operators 'gt' penalty 0)}}
      <label>{{localize 'S0.Penalidade'}}: {{ penalty }}</label>
      {{/if}}
    </div>

    <hr>
    {{/if}}
    <!-- #endregion -->

    {{#if (operators 'gt' automatic 0)}}
    <div class="S0-container-2-column">
      <label>{{localize 'S0.Automatico'}}: {{ automatic }}</label>
    </div>

    <hr>
    {{/if}}

    {{> button-consciousness canUseConsciousness=canUseConsciousness}}
  </div>

  <button class="S0-roll-result {{ resultMessageClasses }}" data-action="view" data-type="toggle-tooltip">
    {{ resultMessage }} ( {{ resultValue }} )
  </button>

</div>