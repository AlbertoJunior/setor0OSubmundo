<label for="{{item.id}}.damage">{{localize 'S0.Dano'}}:</label>
<input id="{{item.id}}.damage" type="number" name="system.damage" min="0" max="6"
  value="{{itemValues item 'damage'}}" />

<label for="{{item.id}}.true_damage">{{localize 'S0.Dano_Automatico'}}:</label>
<input id="{{item.id}}.true_damage" type="number" min="0" max="6" name="system.true_damage"
  value="{{itemValues item 'true_damage'}}" />

<label for="{{item.id}}.damage_type">{{localize 'S0.Tipo_Dano'}}:</label>
<select id="{{item.id}}.damage_type" class="S0-select" name="system.damage_type">
  {{#with (itemValues item 'damage_type') as |damage_type|}}
  {{#each (fetchRepository 'equipment-damage-type')}}
  <option value="{{id}}" {{selectIfEq damage_type id}}>{{label}}</option>
  {{/each}}
  {{/with}}
</select>

<label for="{{item.id}}.hand">{{localize 'S0.Maos'}}:</label>
<select id="{{item.id}}.hand" class="S0-select" name="system.hand">
  {{#with (itemValues item 'hand') as |hand|}}
  {{#each (fetchRepository 'equipment-hand-type')}}
  <option value="{{id}}" {{selectIfEq hand id}}>{{label}}</option>
  {{/each}}
  {{/with}}
</select>

<label for="{{item.id}}.occultability">{{localize 'S0.Ocultabilidade'}}:</label>
<select id="{{item.id}}.occultability" class="S0-select" name="system.occultability">
  {{#with (itemValues item 'occultability') as |occultability|}}
  {{#each (fetchRepository 'equipment-occultability')}}
  <option value="{{id}}" {{selectIfEq occultability id}}>{{label}}</option>
  {{/each}}
  {{/with}}
  </option>
</select>