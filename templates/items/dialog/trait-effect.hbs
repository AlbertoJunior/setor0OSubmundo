<form autocomplete="off">
  <div class="S0-page S0-container">
    <label class="S0-block S0-mb-6" for="effectKey">{{localize 'Efeito'}}</label>
    <select id="effectKey" name="key" class="S0-select S0-mb-16">
      {{selectOptions effectsOptions}}
