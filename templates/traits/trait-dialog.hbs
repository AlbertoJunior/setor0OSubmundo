<div class="S0-dialog S0-container">
  <div class="form-group">
    <label class="S0-max-w-110 S0-font-bold" for="trait">{{ title }}</label>
    <select id="trait" class="S0-select S0-text-start" {{ isEnabledChangeTrait }}>
      {{#each options as |group|}}
      <optgroup label="{{ group.label }}">
        {{#each group.options as |option|}}
        <option data-id="{{ option.id }}" value="{{ option.id }}" {{ option.isSelected }}>
          {{ option.label }}
        </option>
        {{/each}}
      </optgroup>
      {{/each}}
    </select>
  </div>

  <div id="divParticularity">
    <div class="form-group">
      <label class="S0-max-w-110 S0-font-bold" for="particularity">{{ particularity }}:</label>
      <input id="particularity" type="text" {{ isEnabledChangeParticularity }} value="{{ particularityValue }}" />
    </div>
  </div>

  {{#unless (operators 'isNull' morph)}}
  <div class="form-group" id="divMorph">
    <label class="S0-max-w-110 S0-font-bold">{{ morph }}:</label>
    <label class="S0-mx-6" id="morph">{{ morphValue }}</label>
  </div>
  {{/unless}}

  <div class="form-group" id="divRequirement">
    <label class="S0-max-w-110 S0-font-bold">{{ requirement }}:</label>
    <label class="S0-mx-6" id="requirement">{{ requirementValue }}</label>
  </div>

  <div class="form-group">
    <label class="S0-max-w-110 S0-font-bold">{{ cost }}:</label>
    <label class="S0-mx-6" id="cost"></label>
  </div>

  <label class="S0-block S0-font-bold">{{localize 'S0.Descricao'}}:</label>
  <div id="description" class="S0-message-simple-text S0-max-h-330 S0-overflow-y-auto S0-whitespace-pre-wrap">
    {{description}}
  </div>
</div>