<div class="S0-container">
  <h3>{{localize title}}</h3>
  <hr>

  <ul id="{{type}}-{{actor.id}}" class="S0-container-4-column S0-drop-container S0-row-gap-10 S0-justify-items-center">
    {{#each (actorLists actor type)}}
    <li class="S0-actor-images-container">
      <div class="S0-actor-container-button">
        {{#if ../editable}}
        <a class="S0-actor-button S0-icon-expand" data-action="remove" data-characteristic="{{../type}}"
          data-item-id="{{id}}" title="{{localize 'S0.Remover'}}">
          <i class="fas fa-trash"></i>
        </a>
        {{/if}}

        <a class="S0-actor-button S0-icon-expand" data-action="view" data-characteristic="{{../type}}"
          data-item-id="{{id}}" title="{{localize 'S0.Ver_Informacoes'}}">
          <i class="fas fa-eye"></i>
        </a>
      </div>

      <div class="S0-w-full S0-h-full S0-overflow-hidden">
        <img class="S0-actor-images" src="{{img}}" />

        <h4 class="S0-actor-images-name S0-hide-long-text">{{system.morfologia}}</h4>
      </div>

      <h4 class="S0-actor-images-morph S0-hide-long-text">{{name}}</h4>
    </li>
    {{else}}
    <p class="S0-drop-container S0-label-drop-container">
      {{localize 'S0.Nenhum_variavel_Cadastrado' tipo=(localize title_singular)}}
    </p>
    {{/each}}
  </ul>
</div>