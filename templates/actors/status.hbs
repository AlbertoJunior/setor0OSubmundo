<section class="S0-page tab" data-group="menu-tabs" data-tab="status" data-label="{{ localize 'S0.Status' }}"
  id="statusPage" data-icon="fas fa-heart-pulse">

  {{#if (operators 'isNotNull' (actorValues actor 'experience'))}}
  <div class="S0-container">
    <h2>
      {{localize 'S0.Experiencia'}}
    </h2>

    <ul class="S0-ul-flex">
      {{#if editable}}

      {{#if (gameFunc 'isGm')}}
      <li class="S0-container">
        <h3>
          <label for="experiencia.atual">{{localize 'S0.Disponivel'}}</label>
        </h3>
        <h4 class="S0-m-0">
          <input id="experiencia.atual" name="system.experiencia.atual" type="number"
            value="{{actorValues actor 'actual_experience'}}" placeholder="0" />
        </h4>
      </li>
      {{else}}
      <li class="S0-container">
        <h3>{{localize 'S0.Disponivel'}}</h3>
        <h4 class="S0-m-0">{{actorValues actor 'actual_experience'}}</h4>
      </li>
      {{/if}}

      <li class="S0-container">
        <h3>
          <label for="experiencia.usada">{{localize 'S0.Usada'}}</label>
        </h3>
        <h4 class="S0-m-0">
          <input id="experiencia.usada" name="system.experiencia.usada" type="number"
            value="{{actorValues actor 'used_experience'}}" placeholder="0" />
        </h4>
      </li>

      {{else}}

      <li class="S0-container">
        <h3>{{localize 'S0.Disponivel'}}</h3>
        <h4 class="S0-m-0">{{actorValues actor 'actual_experience'}}</h4>
      </li>
      <li class="S0-container">
        <h3>{{localize 'S0.Usada'}}</h3>
        <h4 class="S0-m-0">{{actorValues actor 'used_experience'}}</h4>
      </li>

      {{/if}}

      <li class="S0-container">
        <div class="S0-h-full S0-flex-col S0-justify-center">
          <h3>{{localize 'S0.Total'}}</h3>
          <h4 class="S0-m-0">{{actorValues actor 'total_experience'}}</h4>
        </div>
      </li>
    </ul>
  </div>
  {{/if}}

  <div class="S0-container">
    <h2> {{localize 'S0.Situacao'}}
      {{#if canEdit}}
      <a class="S0-icon-rotate" data-action="remove" data-characteristic="temporary" data-type="all">
        <i class="fas fa-refresh"></i>
      </a>
      {{/if}}
    </h2>

    <ul class="S0-ul-flex">
      <li class="S0-container">
        <h3>{{ localize 'S0.Movimento'}}</h3>
        <h4 class="S0-m-0">{{actorValues actor 'pm'}}</h4>
      </li>
      <li class="S0-container">
        <h3>
          {{ localize 'S0.Iniciativa'}}
          {{#if canEdit}}
          <a class="S0-icon-rotate" data-action="roll" data-characteristic="temporary" data-type="initiative">
            <i class="fas fa-dice-d10"></i>
          </a>
          {{/if}}
        </h3>
        <h4>{{actorValues actor 'initiative'}}</h4>
      </li>
      <li class="S0-container">
        <h3>{{ localize 'S0.Penalidade'}}</h3>
        <h4>{{actorValues actor 'penalty'}}</h4>
      </li>
    </ul>

    <ul class="S0-ul-flex">
      <li class="S0-container">
        <h3>
          {{ localize 'S0.Consciencia'}}
          {{#if canEdit}}
          <a class="S0-icon-rotate" data-action="remove" data-characteristic="temporary" data-type="virtue"
            data-item-type="consciencia">
            <i class="fas fa-refresh"></i>
          </a>
          {{/if}}
        </h3>
        <div id="consciencia" class="S0-inner-container">
          {{#lett actor=actor
          action=(operators 'ternary' canEdit 'check' '')
          selectedClass=(operators 'ternary' canEdit 'S0-clickable' '')}}

          {{#forLoop 0 (actorValues actor 'actual_consciousness')}}
          <div class="S0-characteristic S0-characteristic-temp {{../selectedClass}}" data-action="{{../action}}"
            data-characteristic="temporary" data-type="virtue" data-item-type="consciencia">
          </div>
          {{/forLoop}}

          {{/lett}}
        </div>
      </li>

      <li class="S0-container">
        <h3>
          {{ localize 'S0.Perseveranca'}}
          {{#if canEdit}}
          <a class="S0-icon-rotate" data-action="remove" data-characteristic="temporary" data-type="virtue"
            data-item-type="perseveranca">
            <i class="fas fa-refresh"></i>
          </a>
          {{/if}}
        </h3>
        <div id="perseveranca" class="S0-inner-container">
          {{#lett actor=actor
          action=(operators 'ternary' canEdit 'check' '')
          selectedClass=(operators 'ternary' canEdit 'S0-clickable' '')}}

          {{#forLoop 0 (actorValues actor 'actual_perseverance')}}
          <div class="S0-characteristic S0-characteristic-temp {{../selectedClass}}" data-action="{{../action}}"
            data-characteristic="temporary" data-type="virtue" data-item-type="perseveranca">
          </div>
          {{/forLoop}}

          {{/lett}}
        </div>
      </li>

      <li class="S0-container">
        <h3>
          {{ localize 'S0.Quietude'}}
          {{#if canEdit}}
          <a class="S0-icon-rotate" data-action="remove" data-characteristic="temporary" data-type="virtue"
            data-item-type="quietude">
            <i class="fas fa-refresh"></i>
          </a>
          {{/if}}
        </h3>
        <div id="quietude" class="S0-inner-container">
          {{#lett actor=actor
          action=(operators 'ternary' canEdit 'check' '')
          selectedClass=(operators 'ternary' canEdit 'S0-clickable' '')}}

          {{#forLoop 0 (actorValues actor 'actual_quietness')}}
          <div class="S0-characteristic S0-characteristic-temp {{../selectedClass}}" data-action="{{../action}}"
            data-characteristic="temporary" data-type="virtue" data-item-type="quietude">
          </div>
          {{/forLoop}}

          {{/lett}}
        </div>
      </li>
    </ul>

    <ul class="S0-ul-flex">
      {{#if (operators 'eq' (actorValues actor 'morphology') 'sintetico')}}
      <li class="S0-container">
        <h3>
          {{ localize 'S0.Vida' }}
          {{#if canEdit}}
          <a class="S0-icon-rotate" data-action="roll" data-characteristic="temporary" data-type="life">
            <i class="fas fa-dice-d10"></i>
          </a>
          {{/if}}
        </h3>
        <div id="vida" class="S0-inner-container">
          {{#lett actor=actor
          action=(operators 'ternary' canEdit 'check' '')
          selectedClass=(operators 'ternary' canEdit 'S0-clickable' '')}}

          {{#forLoop 0 10}}
          <div class="S0-characteristic S0-characteristic-temp {{../selectedClass}}" data-action="{{../action}}"
            data-characteristic="temporary" data-type="life">
          </div>
          {{/forLoop}}
          {{/lett}}
        </div>
      </li>
      {{/if}}

      {{#if (operators 'gt' (actorValues actor 'core') 0)}}
      <li class="S0-container">
        {{> actorOverload this}}
      </li>
      {{/if}}
    </ul>

    <ul class="S0-ul-flex">
      {{#if (actorValues actor 'have_equipped_armor') }}
      <div class="S0-container S0-flex-1 S0-flex-col">
        <h3>
          {{ localize 'S0.Protecao' }}
          {{#if canEdit}}
          <a class="S0-icon-rotate" data-action="remove" data-characteristic="temporary" data-type="protect">
            <i class="fas fa-refresh"></i>
          </a>
          {{/if}}
        </h3>

        <div id="protect" class="S0-inner-container S0-wrap S0-flex-1 S0-col-gap-12 S0-row-gap-10">
          {{#lett actor=actor
          action=(operators 'ternary' canEdit 'check' '')
          selectedClass=(operators 'ternary' canEdit 'S0-clickable' '')}}

          {{#forLoop 0 (actorValues actor 'equipped_amor_total_resistance')}}
          <div class="S0-characteristic S0-characteristic-temp {{../selectedClass}}" data-action="{{../action}}"
            data-characteristic="temporary" data-type="protect">
          </div>
          {{/forLoop}}
          {{/lett}}
        </div>
      </div>
      {{/if}}

      <li class="S0-container S0-flex-3">
        <h3>
          {{ localize 'S0.Dano' }}
          <label class="S0-text-11">
            {{actorValues actor 'current_damage'}}/{{actorValues actor 'vitality'}}
          </label>
          {{#if canEdit}}
          <a class="S0-icon-rotate" data-action="remove" data-characteristic="temporary" data-type="health">
            <i class="fas fa-refresh"></i>
          </a>
          {{/if}}
        </h3>
        <div id="vitalidade" class="S0-inner-container">
          {{#lett actor=actor
          action=(operators 'ternary' canEdit 'check_contextual' '')
          selectedClass=(operators 'ternary' canEdit 'S0-clickable' '')}}

          {{#forLoop 0 (actorValues actor 'vitality')}}
          <div class="S0-characteristic S0-characteristic-temp {{../selectedClass}}" data-action="{{../action}}"
            data-characteristic="temporary" data-type="health">
          </div>
          {{/forLoop}}
          {{/lett}}
        </div>

        <div class="S0-container S0-flex S0-mb-2 S0-justify-around">
          <div class="S0-inner-li S0-flex-1">
            <label><strong>{{localize 'S0.Clique_Esquerdo'}}:</strong> {{localize 'S0.Letal'}}</label>
            <div class="S0-characteristic S0-characteristic-temp S0-letal">
            </div>
          </div>
          <div class="S0-inner-li S0-flex-1">
            <label><strong>{{localize 'S0.Clique_Direito'}}:</strong> {{localize 'S0.Superficial'}}</label>
            <div class="S0-characteristic S0-characteristic-temp S0-superficial">
            </div>
          </div>
        </div>
      </li>
    </ul>
  </div>

  <div class="S0-container">
    <h2>
      {{localize 'S0.Efeitos_Ativos'}}
      <a class="S0-icon-expand" data-action="check" data-characteristic="effects" data-type="expand">
        <i id="effects-container-icon" class="fas fa-chevron-up"></i>
      </a>
      {{#if canEdit}}
      <a class="S0-icon-rotate" data-action="check" data-characteristic="effects" data-type="refresh"
        title="{{localize 'S0.Reiniciar_Efeitos_Passivos'}}">
        <i class="fas fa-refresh"></i>
      </a>
      <a class="S0-icon-expand" data-action="remove" data-characteristic="effects" data-type="all"
        title="{{localize 'S0.Remover_Todos_Efeitos'}}">
        <i class="fas fa-trash"></i>
      </a>
      {{/if}}
    </h2>

    <ul id="effects-container" class="S0-container S0-container-contract S0-expanded S0-py-4">
      {{#each (actorLists actor 'effects') as |item|}}
      <li class="S0-flex S0-gap-4 S0-items-center">
        {{#if (itemValues item 'effect_has_type')}}

        {{#if (itemValues item 'effect_is_buff')}}
        <i class="fas fa-arrow-trend-up S0-buff-color"></i>
        {{/if}}

        {{#if (itemValues item 'effect_is_debuff')}}
        <i class="fas fa-arrow-trend-down S0-debuff-color"></i>
        {{/if}}

        {{/if}}

        <span class="S0-hide-long-text S0-flex-1">{{parse 'effect_on_status' item}}</span>
        <a class="S0-icon-expand S0-centralized-icon" data-action="view" data-characteristic="effects"
          data-item-id="{{item._id}}" title="{{localize 'S0.Ver_Efeito'}}">
          <i class="fas fa-eye"></i>
        </a>
        {{#if (operators 'and' (itemValues item 'effect_can_remove') ../canEdit)}}
        <a class="S0-icon-expand S0-centralized-icon" data-action="remove" data-characteristic="effects"
          data-type="single" data-item-id="{{item._id}}" title="{{localize 'S0.Remover_Efeito'}}">
          <i class="fas fa-remove"></i>
        </a>
        {{/if}}
      </li>
      {{/each}}
    </ul>
  </div>
</section>