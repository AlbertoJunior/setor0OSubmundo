<div class="S0-container">
  <h2>
    {{localize 'S0.Manobra.Manobras'}}
    <a class="S0-icon-expand" data-action="view" data-characteristic="maneuvers">
      <i class="fas fa-chevron-up"></i>
    </a>
    {{#if editable}}
    <a class="S0-icon-expand" data-action="add" data-characteristic="maneuvers" title="{{localize 'S0.Adicionar'}}">
      <i class="fas fa-square-plus"></i>
    </a>
    {{/if}}
  </h2>

  {{#if (operators 'isEmpty' (actorLists actor 'maneuvers'))}}
  <div id="maneuvers-{{actor.id}}" class="S0-container-contract S0-expanded S0-drop-container">
    <div class="S0-text-center S0-italic S0-my-4">
      {{localize 'S0.Itens.Mensagens.Nenhum_item_adicionado'}}
    </div>
  </div>
  {{else}}
  <div id="maneuvers-{{actor.id}}" class="S0-flex-col S0-container-contract S0-row-gap-0 S0-expanded S0-drop-container">
    {{#each (actorLists actor 'maneuvers') as |group|}}
    <h3 class="S0-my-2">{{group.label}}</h3>
    <div class="S0-container-3-fixed-column S0-col-gap-4">
      {{#each group.items as |maneuver|}}
      <div class="S0-container S0-flex-col S0-gap-2">
        <label class="S0-text-center S0-font-bold">
          {{maneuver.name}}
        </label>

        <div class="S0-flex S0-items-center S0-mt-4 S0-justify-evenly S0-gap-4">
          <a class="S0-icon-expand S0-centralized-icon" data-action="roll" data-characteristic="maneuvers"
            data-item-id="{{maneuver.id}}" title="{{localize 'S0.Rolar'}}">
            <i class="fas fa-dice-d10"></i>
          </a>

          {{#if ../../editable}}
          <a class="S0-icon-expand S0-centralized-icon" data-action="edit" data-characteristic="maneuvers"
            data-item-id="{{maneuver.id}}" title="{{localize 'S0.Editar'}}">
            <i class="fas fa-edit"></i>
          </a>
          <a class="S0-icon-expand S0-centralized-icon" data-action="remove" data-characteristic="maneuvers"
            data-item-id="{{maneuver.id}}" title="{{localize 'S0.Remover'}}">
            <i class="fas fa-trash"></i>
          </a>
          {{/if}}

          {{#if maneuver.flags.core.sourceId}}
          <a class="S0-icon-expand S0-centralized-icon" data-action="view" data-characteristic="maneuvers"
            data-sub-characteristic="original" data-item-id="{{maneuver.id}}" title="{{localize 'S0.Ver_Informacoes'}}"
            data-source-id="{{maneuver.flags.core.sourceId}}">
            <i class="fas fa-eye"></i>
          </a>
          {{else}}
          <a class="S0-icon-expand S0-centralized-icon" data-action="view" data-characteristic="maneuvers"
            data-item-id="{{maneuver.id}}" title="{{localize 'S0.Ver_Informacoes'}}">
            <i class="fas fa-eye"></i>
          </a>
          {{/if}}

          <a class="S0-icon-expand S0-centralized-icon" data-action="chat" data-characteristic="maneuvers"
            data-item-id="{{maneuver.id}}" title="{{localize 'S0.Enviar_No_Chat'}}">
            <i class="fas fa-message-quote"></i>
          </a>
        </div>
      </div>
      {{/each}}
    </div>
    {{/each}}
  </div>
  {{/if}}
</div>